# Copy this file to .env and fill in real values.
# cp .env.example .env

# ===== 鉴权配置 =====
# 是否启用鉴权（建议生产环境启用）
AUTH_ENABLED=true

# 管理员用户名
ADMIN_USERNAME=admin

# 管理员密码的 SHA256 哈希值
# 生成方法：echo -n "your_password" | sha256sum
# 示例密码 "admin123" 的哈希：
ADMIN_PASSWORD_HASH=240be518fabd2724ddb6f04eeb1da5967448d7e831c08c8fa822809f74c720a9

# ===== SSRF 防护 =====
# Alist 主机白名单（逗号分隔，留空则不限制）
# 示例：ALLOWED_ALIST_HOSTS=alist.example.com,192.168.1.100
ALLOWED_ALIST_HOSTS=

# ===== 环境变量覆盖 Alist 配置 =====
# Set true only when you want environment variables to override sources.json
ALIST_ENV_OVERRIDE_ENABLED=false

# Transcode backend priority for Intel N97 (supported: qsv,vaapi,cpu)
# Example fallback chain: qsv,vaapi,cpu
TRANSCODE_BACKENDS=qsv,vaapi,cpu

# Optional: provide a fixed Fernet key to encrypt JWT tokens at rest.
# If empty, service will auto-generate /app/data/token.key (persisted via volume).
# Generate key command:
# python3 - <<'PY'
# from cryptography.fernet import Fernet
# print(Fernet.generate_key().decode())
# PY
# ALIST_TOKEN_ENC_KEY=

# Source: tgdownloader
ALIST_TGDOWNLOADER_URL=http://your-alist-host:5244
ALIST_TGDOWNLOADER_USERNAME=your_username
ALIST_TGDOWNLOADER_PASSWORD=your_password

# Source: downloads
ALIST_DOWNLOADS_URL=http://your-alist-host:5244
ALIST_DOWNLOADS_USERNAME=your_username
ALIST_DOWNLOADS_PASSWORD=your_password

# Source #3 (素材) uses index-based fallback because non-ASCII names are normalized.
ALIST_SOURCE_3_URL=http://your-alist-host:5244
ALIST_SOURCE_3_USERNAME=your_username
ALIST_SOURCE_3_PASSWORD=your_password
